generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



model Professor {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  department      String
  school          String
  rmpQuality      Float?
  rmpDifficulty   Float?
  rmpWouldTakeAgain Int?
  rmpRatingsCount Int?
  rmpUrl          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([department])
}
