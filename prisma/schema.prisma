generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Professor {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  department        String
  school            String
  rmpQuality        Float?
  rmpDifficulty     Float?
  rmpWouldTakeAgain Int?
  rmpRatingsCount   Int?
  rmpUrl            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  aiSummary         String?

  @@index([name])
  @@index([department])
}

model MissingProfessorReport {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  searchQuery    String?
  professorName  String
  department     String?
  classInput     String?
  notes          String?

  page           String?
  userAgent      String?
}

model Term {
  id              String                      @id @default(cuid())
  code            String                      @unique
  name            String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  instructorStats CourseInstructorTermStats[]
  courseStats     CourseTermStats[]
}

model Course {
  id               String                      @id @default(cuid())
  subject          String
  number           String
  title            String
  deptCode         String?
  deptName         String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  avgGpa           Float?
  difficultyScore  Float?
  totalRegsAllTime Int                         @default(0)
  instructorStats  CourseInstructorTermStats[]
  termStats        CourseTermStats[]

  @@unique([subject, number])
  @@index([deptName])
  @@index([subject, number])
}

model CourseTermStats {
  id        String   @id @default(cuid())
  courseId  String
  termId    String
  gradeRegs Int      @default(0)
  a         Int      @default(0)
  b         Int      @default(0)
  c         Int      @default(0)
  d         Int      @default(0)
  f         Int      @default(0)
  adv       Int      @default(0)
  cr        Int      @default(0)
  dfr       Int      @default(0)
  i         Int      @default(0)
  ng        Int      @default(0)
  nr        Int      @default(0)
  o         Int      @default(0)
  pr        Int      @default(0)
  s         Int      @default(0)
  u         Int      @default(0)
  w         Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([courseId, termId])
  @@index([termId])
}

model CourseInstructorTermStats {
  id             String   @id @default(cuid())
  courseId       String
  termId         String
  instructorName String
  gradeRegs      Int      @default(0)
  a              Int      @default(0)
  b              Int      @default(0)
  c              Int      @default(0)
  d              Int      @default(0)
  f              Int      @default(0)
  adv            Int      @default(0)
  cr             Int      @default(0)
  dfr            Int      @default(0)
  i              Int      @default(0)
  ng             Int      @default(0)
  nr             Int      @default(0)
  o              Int      @default(0)
  pr             Int      @default(0)
  s              Int      @default(0)
  u              Int      @default(0)
  w              Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term           Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([courseId, termId, instructorName])
  @@index([termId])
  @@index([instructorName])
}
