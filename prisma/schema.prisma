generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model Professor {                                                                                                    
   id String @id @default(cuid())                                                                                       
   slug String @unique                                                                                                  
   name String                                                                                                          
   nameNormalized String?                                                                                               
   department String                                                                                                    
   school String                                                                                                        
   rmpQuality Float?                                                                                                    
   rmpDifficulty Float?                                                                                                 
   rmpWouldTakeAgain Int?                                                                                               
   rmpRatingsCount Int?                                                                                                 
   rmpUrl String?                                                                                                       
   createdAt DateTime @default(now())                                                                                   
   updatedAt DateTime @updatedAt                                                                                        
   aiSummary String?
   salary Float?
   salaryTitle String?

   bayesianScore Float? @default(0)                                                                                     
   overallRank Int?                                                                                                     
   departmentRank Int?                                                                                                  
   courseCount Int @default(0)                                                                                          
                                                                                                                        
   courseStats CourseInstructorTermStats[]                                                                              
   reviews ProfessorReview[]                                                                                            
   courseRanks ProfessorCourseRank[]                                                                                    
                                                                                                                        
   @@index([name])                                                                                                      
   @@index([nameNormalized])                                                                                            
   @@index([department])                                                                                                
   @@index([bayesianScore])                                                                                             
   @@index([overallRank])                                                                                               
   @@index([department, departmentRank])                                                                                
   }                     

model ProfessorReview {
  id             String    @id
  professorId    String
  reviewText     String    @db.Text
  quality        Int?
  difficulty     Int?
  wouldTakeAgain Boolean?
  thumbsUp       Int?
  thumbsDown     Int?
  grade          String?
  courseCode     String?
  forCredit      Boolean?
  useTextbook    Boolean?
  attendanceReq  Boolean?
  rmpReviewId    String?   @unique
  scrapedAt      DateTime  @default(now())

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  @@index([professorId])
  @@index([courseCode])
}

model MissingProfessorReport {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  searchQuery   String?
  professorName String
  department    String?
  classInput    String?
  notes         String?
  page          String?
  userAgent     String?
}

model Term {
  id              String                      @id @default(cuid())
  code            String                      @unique
  name            String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  instructorStats CourseInstructorTermStats[]
  courseStats     CourseTermStats[]
}
model Course {                                                                                                       
   id String @id @default(cuid())                                                                                       
   subject String                                                                                                       
   number String                                                                                                        
   title String                                                                                                         
   deptCode String?                                                                                                     
   deptName String?                                                                                                     
   createdAt DateTime @default(now())                                                                                   
   updatedAt DateTime @updatedAt                                                                                        
   avgGpa Float?                                                                                                        
   difficultyScore Float?                                                                                               
   totalRegsAllTime Int @default(0)                                                                                     
   instructorStats CourseInstructorTermStats[]                                                                          
   termStats CourseTermStats[]                                                                                          
   isGenEd Boolean @default(false)                                                                                      
   genEdCategory String?                                                                                                
   professorRanks ProfessorCourseRank[]                                                                                 
                                                                                                                        
   @@unique([subject, number])                                                                                          
   @@index([deptName])                                                                                                  
   @@index([subject, number])                                                                                           
   }              

model ProfessorCourseRank {                                                                                          
   id String @id @default(cuid())                                                                                       
   professorId String                                                                                                   
   courseId String                                                                                                      
                                                                                                                        
   rankInCourse Int?                                                                                                    
   totalProfessors Int @default(0)                                                                                      
                                                                                                                        
   professorBayesianScore Float? @default(0)                                                                            
   avgGpaWithProfessor Float?                                                                                           
   aRateWithProfessor Float?                                                                                            
   wRateWithProfessor Float?                                                                                            
   totalStudents Int @default(0)                                                                                        
                                                                                                                        
   createdAt DateTime @default(now())                                                                                   
   updatedAt DateTime @updatedAt                                                                                        
                                                                                                                        
   professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)                            
   course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)                                     
                                                                                                                        
   @@unique([professorId, courseId])                                                                                    
   @@index([professorId])                                                                                               
   @@index([courseId])                                                                                                  
   @@index([courseId, rankInCourse])                                                                                    
   }        

model NewsItem {
  id          String   @id @default(cuid())
  guid        String   @unique
  source      String
  title       String
  url         String
  publishedAt DateTime
  rawContent  String   @db.Text
  aiSummary   String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([publishedAt])
}

model KnowledgeChunk {
  id                 String                     @id @default(cuid())
  content            String                     @db.Text
  sourceType         String
  sourceId           String?
  chunkType          String?
  entityId           String?
  entityType         String?
  trustLevel         String?
  validUntil         DateTime?
  metadata           String                     @db.Text
  embedding          Unsupported("vector(1024)")?
  embeddingUpdatedAt DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([sourceType])
  @@index([sourceId])
  @@index([chunkType])
  @@index([entityId])
  @@index([trustLevel])
  @@index([embedding])
  @@unique([sourceId, sourceType])
}

model Feedback {
  id        String   @id @default(cuid())
  message   String
  rating    String
  createdAt DateTime @default(now())
}

model ConversationSession {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  memory       String   @db.Text
  sessionState String   @db.Text @default("{}")
  messageCount Int      @default(0)
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionId])
}

model CourseTermStats {
  id        String   @id @default(cuid())
  courseId  String
  termId    String
  gradeRegs Int      @default(0)
  a         Int      @default(0)
  b         Int      @default(0)
  c         Int      @default(0)
  d         Int      @default(0)
  f         Int      @default(0)
  adv       Int      @default(0)
  cr        Int      @default(0)
  dfr       Int      @default(0)
  i         Int      @default(0)
  ng        Int      @default(0)
  nr        Int      @default(0)
  o         Int      @default(0)
  pr        Int      @default(0)
  s         Int      @default(0)
  u         Int      @default(0)
  w         Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([courseId, termId])
  @@index([termId])
}

model CourseInstructorTermStats {
  id             String    @id @default(cuid())
  courseId       String
  termId         String
  instructorName String
  professorId    String?
  gradeRegs      Int       @default(0)
  a              Int       @default(0)
  b              Int       @default(0)
  c              Int       @default(0)
  d              Int       @default(0)
  f              Int       @default(0)
  adv            Int       @default(0)
  cr             Int       @default(0)
  dfr            Int       @default(0)
  i              Int       @default(0)
  ng             Int       @default(0)
  nr             Int       @default(0)
  o              Int       @default(0)
  pr             Int       @default(0)
  s              Int       @default(0)
  u              Int       @default(0)
  w              Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term           Term      @relation(fields: [termId], references: [id], onDelete: Cascade)
  professor      Professor? @relation(fields: [professorId], references: [id], onDelete: SetNull)

  @@unique([courseId, termId, instructorName])
  @@index([termId])
  @@index([instructorName])
  @@index([professorId])
}

model CampusKnowledge {
  id          String   @id @default(cuid())
  domain      String
  entity      String
  key         String
  value       String   @db.Text
  metadata    String   @db.Text
  lastUpdated String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([domain, entity])
  @@index([domain, key])
}

model QueryLog {
  id               String   @id
  sessionId        String
  query            String   @db.Text
  answerMode       String?
  domainsTriggered String?
  retrievalSources String?
  topChunkScore    Float?
  chunkCount       Int?
  abstained        Boolean  @default(false)
  abstainReason    String?
  responseMs       Int?
  createdAt        DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@index([abstained])
  @@index([answerMode])
}