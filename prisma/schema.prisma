generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Professor {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  department        String
  school            String
  rmpQuality        Float?
  rmpDifficulty     Float?
  rmpWouldTakeAgain Int?
  rmpRatingsCount   Int?
  rmpUrl            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  aiSummary         String?

  @@index([name])
  @@index([department])
}

model MissingProfessorReport {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  searchQuery    String?
  professorName  String
  department     String?
  classInput     String?
  notes          String?

  page           String?
  userAgent      String?
}

model Term {
  id              String                      @id @default(cuid())
  code            String                      @unique
  name            String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  instructorStats CourseInstructorTermStats[]
  courseStats     CourseTermStats[]
}

model Course {
  id               String                      @id @default(cuid())
  subject          String
  number           String
  title            String
  deptCode         String?
  deptName         String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  avgGpa           Float?
  difficultyScore  Float?
  totalRegsAllTime Int                         @default(0)
  instructorStats  CourseInstructorTermStats[]
  termStats        CourseTermStats[]
  isGenEd       Boolean  @default(false)
  genEdCategory String?

  @@unique([subject, number])
  @@index([deptName])
  @@index([subject, number])
}


model NewsItem {
  id          String   @id @default(cuid())
  guid        String   @unique
  source      String
  title       String
  url         String
  publishedAt DateTime
  rawContent  String   @db.Text
  aiSummary   String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([publishedAt])
}

model KnowledgeChunk {
  id          String   @id @default(cuid())
  content     String   @db.Text
  sourceType  String
  sourceId    String?
  metadata    String   @db.Text
  embedding   Unsupported("vector(1024)")?
  embeddingUpdatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sourceType])
  @@index([sourceId])
@@index([embedding])
  @@unique([sourceId, sourceType])
}

model Feedback {
  id        String   @id @default(cuid())
  message   String
  rating    String   // "up" or "down"
  createdAt DateTime @default(now())
}

model ConversationSession {
  id          String   @id @default(cuid())
  sessionId   String   @unique        // cookie/browser fingerprint
  memory      String   @db.Text       // JSON: what Sparky knows about this user
  messageCount Int     @default(0)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
}

model CourseTermStats {
  id        String   @id @default(cuid())
  courseId  String
  termId    String
  gradeRegs Int      @default(0)
  a         Int      @default(0)
  b         Int      @default(0)
  c         Int      @default(0)
  d         Int      @default(0)
  f         Int      @default(0)
  adv       Int      @default(0)
  cr        Int      @default(0)
  dfr       Int      @default(0)
  i         Int      @default(0)
  ng        Int      @default(0)
  nr        Int      @default(0)
  o         Int      @default(0)
  pr        Int      @default(0)
  s         Int      @default(0)
  u         Int      @default(0)
  w         Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([courseId, termId])
  @@index([termId])
}



model CourseInstructorTermStats {
  id             String   @id @default(cuid())
  courseId       String
  termId         String
  instructorName String
  gradeRegs      Int      @default(0)
  a              Int      @default(0)
  b              Int      @default(0)
  c              Int      @default(0)
  d              Int      @default(0)
  f              Int      @default(0)
  adv            Int      @default(0)
  cr             Int      @default(0)
  dfr            Int      @default(0)
  i              Int      @default(0)
  ng             Int      @default(0)
  nr             Int      @default(0)
  o              Int      @default(0)
  pr             Int      @default(0)
  s              Int      @default(0)
  u              Int      @default(0)
  w              Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term           Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([courseId, termId, instructorName])
  @@index([termId])
  @@index([instructorName])
}

model CampusKnowledge {
  id        String   @id @default(cuid())
  domain    String   // "housing" | "dining" | "tuition" | "health" | etc
  entity    String   // "ARC" | "JST" | "aspire_grant" | "counseling_center" etc
  key       String   // "cost_per_semester" | "address" | "phone" | "hours" etc
  value     String   @db.Text  // the actual fact
  metadata  String   @db.Text  // JSON: extra structured data
  lastUpdated String // "2025-2026"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
  @@index([domain, entity])
  @@index([domain, key])
}